      "updated": 1783313582785,
      "link": null,
      "locked": false,
      "text": "\n\n\n\n#  Employee APIs\n\n## Authentication\n\nPOST    /auth/login\nPOST    /auth/logout\nPUT     /auth/change-password\nGET     /auth/me\n\n\n\n## Profile\n\nGET     /employee/profile\nPUT     /employee/profile\nPUT     /employee/profile-picture\n\n\n\n## Attendance\n\nPOST    /attendance/check-in\nPOST    /attendance/check-out\n\nGET     /attendance/today\nGET     /attendance/history\nGET     /attendance/monthly\n\n\n\n## Leave\n\nPOST    /leave/apply\nGET     /leave/history\nGET     /leave/:leaveId\nDELETE  /leave/:leaveId\n\n\n\n## Payroll\n\nGET     /payroll/my\nGET     /payroll/my/:month/:year\n\n\n\n\n\n",
      "fontSize": 17.635748309829435,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\n\n\n#  Employee APIs\n\n## Authentication\n\nPOST    /auth/login\nPOST    /auth/logout\nPUT     /auth/change-password\nGET     /auth/me\n\n\n\n## Profile\n\nGET     /employee/profile\nPUT     /employee/profile\nPUT     /employee/profile-picture\n\n\n\n## Attendance\n\nPOST    /attendance/check-in\nPOST    /attendance/check-out\n\nGET     /attendance/today\nGET     /attendance/history\nGET     /attendance/monthly\n\n\n\n## Leave\n\nPOST    /leave/apply\nGET     /leave/history\nGET     /leave/:leaveId\nDELETE  /leave/:leaveId\n\n\n\n## Payroll\n\nGET     /payroll/my\nGET     /payroll/my/:month/:year\n\n\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
