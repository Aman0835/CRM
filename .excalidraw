      "text": "#  Admin APIs\n\n## Dashboard\n\nGET     /admin/dashboard\nGET     /admin/dashboard/stats\nGET     /admin/dashboard/attendance-summary\nGET     /admin/dashboard/payroll-summary\nGET     /admin/dashboard/leave-summary\nGET     /admin/dashboard/recent-activities\n\n\n\n## Employee Management\n\nGET     /admin/employees\nGET     /admin/employees/:employeeId\nPOST    /admin/employees\nPUT     /admin/employees/:employeeId\nDELETE  /admin/employees/:employeeId\nPATCH   /admin/employees/:employeeId/status\n\n\n\n## Attendance Management\n\nGET     /admin/attendance\nGET     /admin/attendance/:employeeId\nGET     /admin/attendance/date/:date\nGET     /admin/attendance/report\n\nPUT     /admin/attendance/:attendanceId\nDELETE  /admin/attendance/:attendanceId\n\n\n\n## Leave Management\n\nGET     /admin/leaves\nGET     /admin/leaves/:leaveId\n\nPATCH   /admin/leaves/:leaveId/approve\nPATCH   /admin/leaves/:leaveId/reject\n\nDELETE  /admin/leaves/:leaveId\n\n\n\n## Payroll Management\n\nPOST    /admin/payroll/generate\n\nGET     /admin/payroll\nGET     /admin/payroll/:employeeId\nGET     /admin/payroll/month/:month/:year\n\nPUT     /admin/payroll/:payrollId\n\n\n\n## Holiday Management\n\nGET     /admin/holidays\nPOST    /admin/holidays\n\nPUT     /admin/holidays/:holidayId\nDELETE  /admin/holidays/:holidayId\n\n\n\n## Reports\n\nGET     /admin/reports/attendance\nGET     /admin/reports/payroll\nGET     /admin/reports/leaves\nGET     /admin/reports/employees\nGET     /admin/reports/monthly\nGET     /admin/reports/custom\n\n\n\n## Export\n\nGET     /admin/export/attendance/pdf\nGET     /admin/export/attendance/excel\n\nGET     /admin/export/payroll/pdf\nGET     /admin/export/payroll/excel\n\nGET     /admin/export/employees/pdf\nGET     /admin/export/employees/excel\n\nGET     /admin/export/leaves/pdf\nGET     /admin/export/leaves/excel",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#  Admin APIs\n\n## Dashboard\n\nGET     /admin/dashboard\nGET     /admin/dashboard/stats\nGET     /admin/dashboard/attendance-summary\nGET     /admin/dashboard/payroll-summary\nGET     /admin/dashboard/leave-summary\nGET     /admin/dashboard/recent-activities\n\n\n\n## Employee Management\n\nGET     /admin/employees\nGET     /admin/employees/:employeeId\nPOST    /admin/employees\nPUT     /admin/employees/:employeeId\nDELETE  /admin/employees/:employeeId\nPATCH   /admin/employees/:employeeId/status\n\n\n\n## Attendance Management\n\nGET     /admin/attendance\nGET     /admin/attendance/:employeeId\nGET     /admin/attendance/date/:date\nGET     /admin/attendance/report\n\nPUT     /admin/attendance/:attendanceId\nDELETE  /admin/attendance/:attendanceId\n\n\n\n## Leave Management\n\nGET     /admin/leaves\nGET     /admin/leaves/:leaveId\n\nPATCH   /admin/leaves/:leaveId/approve\nPATCH   /admin/leaves/:leaveId/reject\n\nDELETE  /admin/leaves/:leaveId\n\n\n\n## Payroll Management\n\nPOST    /admin/payroll/generate\n\nGET     /admin/payroll\nGET     /admin/payroll/:employeeId\nGET     /admin/payroll/month/:month/:year\n\nPUT     /admin/payroll/:payrollId\n\n\n\n## Holiday Management\n\nGET     /admin/holidays\nPOST    /admin/holidays\n\nPUT     /admin/holidays/:holidayId\nDELETE  /admin/holidays/:holidayId\n\n\n\n## Reports\n\nGET     /admin/reports/attendance\nGET     /admin/reports/payroll\nGET     /admin/reports/leaves\nGET     /admin/reports/employees\nGET     /admin/reports/monthly\nGET     /admin/reports/custom\n\n\n\n## Export\n\nGET     /admin/export/attendance/pdf\nGET     /admin/export/attendance/excel\n\nGET     /admin/export/payroll/pdf\nGET     /admin/export/payroll/excel\n\nGET     /admin/export/employees/pdf\nGET     /admin/export/employees/excel\n\nGET     /admin/export/leaves/pdf\nGET     /admin/export/leaves/excel",
      "autoResize": true,
      "lineHeight": 1.25
    },
