# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local: mongodb://127.0.0.1:27017/barbershop_admin
# Production (MongoDB Atlas): mongodb+srv://<user>:<password>@cluster.mongodb.net/barbershop_admin
MONGODB_URI=mongodb://127.0.0.1:27017/barbershop_admin

# Authentication
JWT_SECRET=super_secret_jwt_key_change_in_production

# Frontend Client URLs (Allows multiple origins separated by comma)
# Local: http://localhost:5173
# Production: https://your-admin-frontend.vercel.app
CLIENT_URL=http://localhost:5173

# Local: http://localhost:5174
# Production: https://your-employee-frontend.vercel.app
EMPLOYEE_CLIENT_URL=http://localhost:5174

# Initial Admin Credentials
ADMIN_EMAIL=admin@diva.com
ADMIN_PASSWORD=admin123
